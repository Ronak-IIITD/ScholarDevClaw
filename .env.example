# ScholarDevClaw Environment Variables

# OpenClaw Configuration
OPENCLAW_TOKEN=your-openclaw-token-here

# Convex Configuration
CONVEX_URL=your-convex-deployment-url

# GitHub Configuration  
GITHUB_TOKEN=your-github-token-here

# Anthropic API (for OpenClaw agent)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Python Core Configuration
CORE_API_URL=http://localhost:8000
PYTHON_COMMAND=python3

# Core API hardening (required in production)
SCHOLARDEVCLAW_API_AUTH_KEY=replace-with-strong-random-key

# Colon-separated list of allowed repository base paths for API operations
# Example: /home/user/projects:/repos
SCHOLARDEVCLAW_ALLOWED_REPO_DIRS=/home/user/projects

# Enable strict transport security headers when serving over HTTPS
SCHOLARDEVCLAW_ENABLE_HSTS=true

# Execution Mode: step_approval | autonomous
DEFAULT_MODE=step_approval
