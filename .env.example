# ScholarDevClaw Environment Variables
# Copy this file to .env and fill in the values.

# ==========================================
# CORE CREDENTIALS
# ==========================================

# OpenClaw Configuration (agent orchestration)
OPENCLAW_TOKEN=your-openclaw-token-here
OPENCLAW_API_URL=http://localhost:3000

# Convex Configuration (state persistence)
CONVEX_URL=your-convex-deployment-url
SCHOLARDEVCLAW_CONVEX_AUTH_KEY=your-convex-auth-key-here

# GitHub Configuration (repo access, app integration)
GITHUB_TOKEN=your-github-token-here
# For GitHub App (optional):
# GITHUB_APP_ID=your-app-id
# GITHUB_APP_PRIVATE_KEY=your-private-key
# GITHUB_APP_INSTALLATION_ID=your-installation-id
# GITHUB_APP_WEBHOOK_SECRET=your-webhook-secret

# Core API Authentication (required in production)
SCHOLARDEVCLAW_API_AUTH_KEY=replace-with-strong-random-key
# Optional: set provider and model via env
# SCHOLARDEVCLAW_API_PROVIDER=anthropic
# SCHOLARDEVCLAW_API_MODEL=claude-3-opus-20240229

# ==========================================
# LLM PROVIDER API KEYS
# ==========================================
# Set the key for the provider you use (see SCHOLARDEVCLAW_API_PROVIDER).
# At least one of these is required for LLM-powered features.

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
# Or GOOGLE_API_KEY

# OpenRouter (access multiple models)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Groq
GROQ_API_KEY=your-groq-api-key-here

# Mistral
MISTRAL_API_KEY=your-mistral-api-key-here

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Cohere
COHERE_API_KEY=your-cohere-api-key-here

# xAI (Grok)
XAI_API_KEY=your-xai-api-key-here

# Moonshot
MOONSHOT_API_KEY=your-moonshot-api-key-here

# GLM (Zhipu AI)
GLM_API_KEY=your-glm-api-key-here

# MiniMax
MINIMAX_API_KEY=your-minimax-api-key-here

# Together AI
TOGETHER_API_KEY=your-together-api-key-here

# Fireworks AI
FIREWORKS_API_KEY=your-fireworks-api-key-here

# Ollama (local, no key needed, but can set host)
# OLLAMA_HOST=http://localhost:11434

# ==========================================
# SECURITY & ACCESS CONTROL
# ==========================================

# Colon-separated list of allowed repository base paths for API operations
# Example: /home/user/projects:/repos
SCHOLARDEVCLAW_ALLOWED_REPO_DIRS=/home/user/projects

# CORS origins for API server (comma-separated)
# Example: http://localhost:3000,https://yourdomain.com
SCHOLARDEVCLAW_CORS_ORIGINS=http://localhost:3000

# Enable strict transport security headers when serving over HTTPS
SCHOLARDEVCLAW_ENABLE_HSTS=true

# ==========================================
# EXECUTION & SANDBOXING
# ==========================================

# Python Core Configuration
CORE_API_URL=http://localhost:8000
PYTHON_COMMAND=python3

# Execution Mode: step_approval | autonomous
DEFAULT_MODE=step_approval

# Validation sandbox settings
# SCHOLARDEVCLAW_VALIDATION_SANDBOX=docker
# SCHOLARDEVCLAW_VALIDATION_DOCKER_IMAGE=python:3.10-slim
# SCHOLARDEVCLAW_ROLLBACK_DIR=/tmp/scholardevclaw_rollbacks

# ==========================================
# MONITORING & LOGGING (OPTIONAL)
# ==========================================

# Grafana (if used)
# GRAFANA_ADMIN_PASSWORD=change_me_in_production

# SSL key log file (for debugging)
# SSLKEYLOGFILE=/path/to/keylog.log

# ==========================================
# OAUTH (OPTIONAL, for identity providers)
# ==========================================
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_SCOPES=openid,profile,email
