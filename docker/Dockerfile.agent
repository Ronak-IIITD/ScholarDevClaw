FROM node:22-alpine AS builder

WORKDIR /app

RUN apk add --no-cache libc6-compat

COPY agent/package.json agent/bun.lock* ./

# SECURITY: Pin bun version; must support bun.lock text format (>=1.2)
# corepack does not support bun; install via the official npm package
RUN npm install -g bun@1.3.10

# Install ALL dependencies (including devDependencies) so tsc is available for the build
RUN bun install --frozen-lockfile

COPY agent/ ./

RUN bun run build

# Reinstall production-only dependencies to keep the final image lean
RUN bun install --frozen-lockfile --production

FROM node:22-alpine AS production

WORKDIR /app

RUN addgroup -S -g 1001 agent \
    && adduser -S -u 1001 -G agent agent

COPY --from=builder --chown=agent:agent /app/node_modules ./node_modules
COPY --from=builder --chown=agent:agent /app/dist ./dist
COPY --from=builder --chown=agent:agent /app/package.json ./

RUN mkdir -p /app/data /app/logs \
    && chown -R agent:agent /app

USER agent

ENV NODE_ENV=production
ENV NODE_OPTIONS="--max-old-space-size=512"

EXPOSE 3000

CMD ["node", "dist/index.js"]
