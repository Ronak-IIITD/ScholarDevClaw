CORE_API_URL=http://core-api:8000

# Required in production: Bearer auth key for core API
SCHOLARDEVCLAW_API_AUTH_KEY=replace_with_strong_api_key

# Required in production: colon-separated list of allowed repo root directories
# Example: /repos:/workspace
SCHOLARDEVCLAW_ALLOWED_REPO_DIRS=/repos

# Recommended in production when behind HTTPS
SCHOLARDEVCLAW_ENABLE_HSTS=true

# Required in production: comma-separated UI origins allowed to call API
SCHOLARDEVCLAW_CORS_ORIGINS=https://scholardevclaw.ai,https://www.scholardevclaw.ai

# Agent core bridge mode: http (default) or subprocess
CORE_BRIDGE_MODE=http

OPENCLAW_TOKEN=your_openclaw_token_here
OPENCLAW_API_URL=https://your-openclaw-api-url
CONVEX_URL=https://your-convex-deployment.convex.cloud
GITHUB_TOKEN=your_github_token_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional provider/model pinning for pipeline + agent
SCHOLARDEVCLAW_API_PROVIDER=anthropic
SCHOLARDEVCLAW_API_MODEL=claude-sonnet-4-20250514

# Optional alternative provider keys (set the ones you use)
# OPENAI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# COHERE_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# OLLAMA_HOST=http://localhost:11434

LOG_LEVEL=INFO

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_production
