CORE_API_URL=http://core-api:8000

# Required in production: Bearer auth key for core API
SCHOLARDEVCLAW_API_AUTH_KEY=replace_with_strong_api_key

# Required in production: colon-separated list of allowed repo root directories
# Example: /repos:/workspace
SCHOLARDEVCLAW_ALLOWED_REPO_DIRS=/repos

# Recommended in production when behind HTTPS
SCHOLARDEVCLAW_ENABLE_HSTS=true

OPENCLAW_TOKEN=your_openclaw_token_here
CONVEX_URL=https://your-convex-deployment.convex.cloud
GITHUB_TOKEN=your_github_token_here
ANTHROPIC_API_KEY=your_anthropic_key_here

LOG_LEVEL=INFO

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_production
