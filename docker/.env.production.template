# Production environment template for ScholarDevClaw

# Core API hardening
SCHOLARDEVCLAW_API_AUTH_KEY=__SCHOLARDEVCLAW_API_AUTH_KEY__
SCHOLARDEVCLAW_ALLOWED_REPO_DIRS=/repos
SCHOLARDEVCLAW_CORS_ORIGINS=https://scholardevclaw.ai,https://www.scholardevclaw.ai
SCHOLARDEVCLAW_ENABLE_HSTS=true

# Agent/core bridge
CORE_BRIDGE_MODE=http
CORE_API_URL=http://core-api:8000

# OpenClaw/Convex
OPENCLAW_TOKEN=__OPENCLAW_TOKEN__
OPENCLAW_API_URL=__OPENCLAW_API_URL__
CONVEX_URL=__CONVEX_URL__

# Provider selection (set provider + matching key)
SCHOLARDEVCLAW_API_PROVIDER=anthropic
SCHOLARDEVCLAW_API_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=__ANTHROPIC_API_KEY__

# Optional provider alternatives
# OPENAI_API_KEY=__OPENAI_API_KEY__
# OPENROUTER_API_KEY=__OPENROUTER_API_KEY__
# GROQ_API_KEY=__GROQ_API_KEY__
# DEEPSEEK_API_KEY=__DEEPSEEK_API_KEY__
# MISTRAL_API_KEY=__MISTRAL_API_KEY__
# COHERE_API_KEY=__COHERE_API_KEY__
# TOGETHER_API_KEY=__TOGETHER_API_KEY__
# FIREWORKS_API_KEY=__FIREWORKS_API_KEY__
# OLLAMA_HOST=http://localhost:11434

# Monitoring
GRAFANA_ADMIN_USER=__GRAFANA_ADMIN_USER__
GRAFANA_ADMIN_PASSWORD=__GRAFANA_ADMIN_PASSWORD__

# Logging
LOG_LEVEL=INFO
