# Optional API base URL for production deployments.
# Leave empty when the frontend is served by the same origin and nginx proxies /api.
VITE_API_URL=

# Optional explicit websocket endpoint for pipeline stream.
# Example: wss://example.com/api/ws/pipeline
VITE_WS_URL=

# Optional Vite dev server proxy target.
# Used by `npm run dev` for /api and /health proxying.
VITE_DEV_API_TARGET=http://127.0.0.1:8000
